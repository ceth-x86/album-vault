---
import Layout from '../../layouts/Layout.astro';
import catalog from '../../../../state/catalog.json';
import fs from 'node:fs';
import path from 'node:path';
import { Marked } from 'marked';

export function getStaticPaths() {
  return catalog.map((album) => ({
    params: { slug: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;
const guidePath = path.join(process.cwd(), '..', album.source_file);
let guideContent = '';

if (fs.existsSync(guidePath)) {
  guideContent = fs.readFileSync(guidePath, 'utf-8');
  // Strip main header
  guideContent = guideContent.replace(/^#\s.*?\n/, '');
}

const marked = new Marked();
const guideHtml = marked.parse(guideContent);
---

<Layout title={`${album.album} - ${album.artist}`}>
	<div class="editorial-container">
        <aside class="album-sidebar">
            <div class="sidebar-sticky">
                <img 
                    src={album.cover_path ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${album.cover_path}` : `${import.meta.env.BASE_URL.replace(/\/$/, '')}/placeholder-cover.jpg`} 
                    alt={album.album}
                    class="hero-cover"
                    transition:name={`cover-${album.slug}`} 
                />
                <div class="quick-meta">
                    <p class="label">Artist</p>
                    <p class="value">{album.artist}</p>
                    <p class="label">Release Year</p>
                    <p class="value">{album.year}</p>
                    <a href={import.meta.env.BASE_URL.replace(/\/$/, '') + '/'} class="back-nav">← Back to archive</a>
                </div>
            </div>
        </aside>

        <article class="album-content">
            <header class="content-header">
                <h1 class="main-title">{album.album}</h1>
            </header>
            
            <div class="guide-body" set:html={guideHtml} />
        </article>
	</div>
</Layout>

<style is:global>
    /* Editorial Typography inside guide-body */
    .guide-body h2 {
        font-family: var(--serif);
        font-size: 2.5rem;
        margin-top: 4rem;
        margin-bottom: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 1rem;
    }
    .guide-body p {
        font-size: 1.15rem;
        line-height: 1.7;
        margin-bottom: 1.5rem;
        color: rgba(255,255,255,0.85);
        font-weight: 300;
    }
    .guide-body blockquote {
        margin: 4rem 0;
        padding: 0;
        font-family: var(--serif);
        font-size: 2rem;
        font-style: italic;
        color: var(--text-main);
        line-height: 1.3;
        text-align: center;
        border: none;
    }
    .guide-body blockquote p { font-size: inherit; color: inherit; }
    .guide-body strong {
        color: var(--text-main);
        font-weight: 600;
        letter-spacing: 0.02em;
    }
    .guide-body ul {
        list-style: none;
        padding: 0;
        margin: 2rem 0;
    }
    .guide-body li {
        margin-bottom: 1.5rem;
        padding-left: 2rem;
        position: relative;
    }
    .guide-body li::before {
        content: "—";
        position: absolute;
        left: 0;
        color: var(--text-muted);
    }
</style>

<style>
	.editorial-container {
		display: grid;
		grid-template-columns: 400px 1fr;
		gap: 6rem;
        align-items: flex-start;
	}

    .sidebar-sticky {
        position: sticky;
        top: 4rem;
    }
    
    .hero-cover {
        width: 100%;
        aspect-ratio: 1;
        object-fit: cover;
        box-shadow: 0 30px 60px rgba(0,0,0,0.8);
        border-radius: 4px;
    }

    .quick-meta {
        margin-top: 3rem;
        font-family: var(--mono);
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.1em;
    }
    .label { color: var(--text-muted); margin: 1.5rem 0 0.25rem; }
    .value { color: var(--text-main); margin: 0; font-size: 0.9rem; }
    
    .back-nav {
        display: inline-block;
        margin-top: 4rem;
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.3s;
    }
    .back-nav:hover { color: var(--text-main); }

    .album-content {
        max-width: 700px;
    }
    .main-title {
        font-size: 8rem;
        line-height: 0.85;
        letter-spacing: -0.04em;
        margin: 0 0 4rem;
    }

    @media (max-width: 1024px) {
        .editorial-container { grid-template-columns: 1fr; gap: 4rem; }
        .sidebar-sticky { position: static; }
        .hero-cover { max-width: 400px; }
        .main-title { font-size: 5rem; }
    }
</style>

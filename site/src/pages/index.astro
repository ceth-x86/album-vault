---
import Layout from '../layouts/Layout.astro';
import catalog from '../../../state/catalog.json';

// Sort catalog by year descending
const sortedCatalog = [...catalog].sort((a, b) => (b.year || 0) - (a.year || 0));
---

<Layout title="Album Vault">
	<header class="hero">
        <h1 class="main-title">ALBUM VAULT</h1>
        <p class="subtitle">A curated index of deep listening experiences.</p>
    </header>

	<ul class="album-grid">
		{sortedCatalog.map((album) => (
			<li class="album-card">
				<a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/albums/${album.slug}`}>
					<div class="image-container">
                        <img 
                            src={album.cover_path ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${album.cover_path}` : `${import.meta.env.BASE_URL.replace(/\/$/, '')}/placeholder-cover.svg`} 
                            alt={album.album}
                            transition:name={`cover-${album.slug}`} 
                        />
                    </div>
					<div class="album-info">
                        <div class="meta-row">
                            <span class="year">{album.year}</span>
                            <span class="divider">/</span>
                            <span class="artist-name">{album.artist}</span>
                        </div>
						<h2 class="album-title">{album.album}</h2>
					</div>
				</a>
			</li>
		))}
	</ul>
</Layout>

<style>
	.hero {
		text-align: center;
		margin-bottom: 6rem;
        padding-top: 2rem;
	}
	.main-title {
		font-size: 5rem;
		letter-spacing: -0.02em;
		margin: 0;
        line-height: 0.9;
        text-transform: uppercase;
	}
    .subtitle {
        font-family: var(--mono);
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.8rem;
        margin-top: 1rem;
    }

	.album-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 3rem 1.5rem;
		padding: 0;
		list-style: none;
	}

	.album-card a {
		text-decoration: none;
		color: inherit;
        display: block;
	}
	
    .image-container {
        position: relative;
        overflow: hidden;
        border-radius: 2px;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }
    
    .album-card:hover .image-container {
        transform: scale(1.04);
    }

	.album-card img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
        display: block;
	}

	.album-info {
		padding: 1rem 0;
	}
    
    .meta-row {
        font-family: var(--mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .divider { opacity: 0.2; }

	.album-title {
		margin: 0;
		font-size: 1.1rem;
        line-height: 1.2;
        letter-spacing: 0;
	}

    @media (max-width: 1200px) {
        .album-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 768px) {
        .main-title { font-size: 3rem; }
        .album-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    }
</style>

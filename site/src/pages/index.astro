---
import Layout from '../layouts/Layout.astro';
import catalog from '../../../state/catalog.json';

// Sort catalog by year descending
const sortedCatalog = [...catalog].sort((a, b) => (b.year || 0) - (a.year || 0));
---

<Layout title="Album Vault">
	<header class="hero">
        <h1 class="main-title">ALBUM VAULT</h1>
        <p class="subtitle">A curated index of deep listening experiences.</p>
        
        <div class="search-container">
            <input 
                type="text" 
                id="album-search" 
                placeholder="Search by artist or album..." 
                autocomplete="off"
                autocorrect="off"
                autocapitalize="none"
                spellcheck="false"
            />
        </div>
    </header>

	<ul class="album-grid" id="album-grid">
		{sortedCatalog.map((album, index) => (
			<li class="album-card" data-artist={album.artist.toLowerCase()} data-album={album.album.toLowerCase()}>
				<a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/albums/${album.slug}`}>
					<div class="image-container">
                        <img 
                            src={album.cover_path ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${album.cover_path}` : `${import.meta.env.BASE_URL.replace(/\/$/, '')}/placeholder-cover.svg`} 
                            alt={album.album}
                            transition:name={`cover-${album.slug}`}
                            loading={index < 5 ? "eager" : "lazy"}
                            decoding="async"
                        />
                    </div>
					<div class="album-info">
                        <div class="meta-row">
                            <span class="year">{album.year}</span>
                            <span class="divider">/</span>
                            <span class="artist-name">{album.artist}</span>
                        </div>
						<h2 class="album-title">{album.album}</h2>
					</div>
				</a>
			</li>
		))}
	</ul>
</Layout>

<script>
    const initSearch = () => {
        const searchInput = document.getElementById('album-search') as HTMLInputElement;
        const albumCards = document.querySelectorAll('.album-card') as NodeListOf<HTMLElement>;

        if (!searchInput) return;

        searchInput.addEventListener('input', (e) => {
            const query = (e.target as HTMLInputElement).value.toLowerCase();
            
            albumCards.forEach(card => {
                const artist = card.getAttribute('data-artist') || '';
                const album = card.getAttribute('data-album') || '';
                
                if (artist.includes(query) || album.includes(query)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    };

    // Initialize on page load and after each navigation for View Transitions
    document.addEventListener('astro:page-load', initSearch);
</script>

<style>
	.hero {
		text-align: center;
		margin-bottom: 6rem;
        padding-top: 2rem;
	}
    .search-container {
        margin-top: 3rem;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }
    #album-search {
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding: 0.75rem 0;
        color: var(--text-main);
        font-family: var(--sans);
        font-size: 0.9rem;
        text-align: center;
        outline: none;
        transition: border-color 0.3s;
    }
    #album-search:focus {
        border-bottom-color: var(--text-main);
    }
    #album-search::placeholder {
        color: var(--text-muted);
        opacity: 0.5;
    }

	.main-title {
		font-size: 5rem;
		letter-spacing: -0.02em;
		margin: 0;
        line-height: 0.9;
        text-transform: uppercase;
	}
    .subtitle {
        font-family: var(--mono);
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.8rem;
        margin-top: 1rem;
    }

	.album-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 3rem 1.5rem;
		padding: 0;
		list-style: none;
	}

	.album-card a {
		text-decoration: none;
		color: inherit;
        display: block;
	}
	
    .image-container {
        position: relative;
        overflow: hidden;
        border-radius: 2px;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
    }
    
    .album-card:hover .image-container {
        transform: scale(1.04);
    }

	.album-card img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
        display: block;
	}

	.album-info {
		padding: 1rem 0;
	}
    
    .meta-row {
        font-family: var(--mono);
        font-size: 0.65rem;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    .divider { opacity: 0.2; }

	.album-title {
		margin: 0;
		font-size: 1.1rem;
        line-height: 1.2;
        letter-spacing: 0;
	}

    @media (max-width: 1200px) {
        .album-grid { grid-template-columns: repeat(3, 1fr); }
    }
    @media (max-width: 768px) {
        .main-title { font-size: 3rem; }
        .album-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem; }
    }
</style>
